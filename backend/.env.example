# Backend Environment Variables
# This file contains template values for environment variables
# Copy this file to .env and fill in your actual values

# Gemini AI Configuration (Optional - for AI advisor features)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Note: The backend works without Gemini API key, but AI advisor will use fallback responses
